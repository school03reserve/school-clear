<!DOCTYPE html>
<html lang="uk" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Гімназія ПРОСВІТ — офіційний сайт | м. Лубни") }}</title>
    
    <!-- Canonical URL -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <!-- Meta Description for SEO -->
    <meta name="description" content="{{ description | default(site.description) }}">
    <meta name="keywords" content="{{ site.keywords }}">
    <meta name="author" content="{{ site.nameFull }}">
    <meta name="robots" content="index, follow">
    <meta name="language" content="Ukrainian">
    <meta name="geo.region" content="UA-53">
    <meta name="geo.placename" content="Лубни">
    
    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#0d9488">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="uk_UA">
    <meta property="og:title" content="{{ title | default(site.name) }}">
    <meta property="og:description" content="{{ description | default(site.description) }}">
    <meta property="og:image" content="{{ site.url }}/assets/images/logo.png">
    <meta property="og:image:width" content="512">
    <meta property="og:image:height" content="512">
    <meta property="og:image:alt" content="Логотип Гімназії ПРОСВІТ">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta property="twitter:title" content="{{ title | default(site.name) }}">
    <meta property="twitter:description" content="{{ description | default(site.description) }}">
    <meta property="twitter:image" content="{{ site.url }}/assets/images/logo.png">
    
    <!-- JSON-LD Structured Data (Schema.org) -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "@id": "{{ site.url }}/#organization",
        "name": "{{ site.nameFull }}",
        "alternateName": ["{{ site.name }}", "Гімназія ПРОСВІТ Лубни", "Школа ПРОСВІТ", "Gymnasium Prosvit"],
        "url": "{{ site.url }}",
        "logo": "{{ site.url }}{{ site.logo }}",
        "image": "{{ site.url }}{{ site.logo }}",
        "description": "{{ site.description }}",
        "foundingDate": "{{ site.foundingYear }}",
        "telephone": "+{{ site.phone }}",
        "email": "{{ site.email }}",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ site.address.streetAddress }}",
            "addressLocality": "{{ site.address.addressLocality }}",
            "addressRegion": "{{ site.address.addressRegion }}",
            "postalCode": "{{ site.address.postalCode }}",
            "addressCountry": "{{ site.address.addressCountry }}"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 50.0167,
            "longitude": 33.0167
        },
        "sameAs": [
            "{{ site.facebook }}"
        ],
        "areaServed": {
            "@type": "City",
            "name": "Лубни"
        },
        "parentOrganization": {
            "@type": "Organization",
            "name": "Лубенська міська рада"
        }
    }
    </script>

    <!-- WebSite Schema (for Google site name & search box) -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "Гімназія \"ПРОСВІТ\" ЛМР",
        "alternateName": ["{{ site.name }}", "{{ site.nameFull }}", "Gymnasium Prosvit Lubny"],
        "description": "{{ site.description }}",
        "publisher": {
            "@id": "{{ site.url }}/#organization"
        },
        "inLanguage": "uk-UA"
    }
    </script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/styles.css">
    
    <!-- Alpine.js Collapse Plugin + Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Netlify Identity -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-gray-50 text-secondary font-body flex flex-col min-h-screen antialiased selection:bg-accent selection:text-white" x-data="{ contactOpen: false }">

    <!-- Facebook SDK -->
    <div id="fb-root"></div>
    <script async defer crossorigin="anonymous" src="https://connect.facebook.net/uk_UA/sdk.js#xfbml=1&version=v18.0" nonce="RANDOM"></script>

    <!-- Top Bar (Optional, for quick info like phone/socials) -->
    <div class="bg-gray-50 text-gray-600 text-xs py-2 border-b border-gray-200 hidden md:block relative z-50">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <div class="flex space-x-6">
                <a href="https://maps.app.goo.gl/r652sF9" target="_blank" class="flex items-center hover:text-primary transition-colors">
                    <svg class="w-3.5 h-3.5 mr-1.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span>вул. Олександрівська, 8/2, 37500, м. Лубни</span>
                </a>
                <a href="tel:+380536161815" class="flex items-center hover:text-primary transition-colors">
                    <svg class="w-3.5 h-3.5 mr-1.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <span>+38 (053) 616-18-15</span>
                </a>
            </div>
            <!-- Socials -->
        <div class="flex items-center space-x-4">
            <a href="https://www.facebook.com/gymnasium.prosvit/" target="_blank" class="text-gray-500 hover:text-[#1877F2] transition-colors" aria-label="Facebook">
                <span class="hidden md:inline text-xs font-semibold mr-1">Facebook</span>
                <svg class="w-5 h-5 inline-block" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="mailto:school3_lubny@ukr.net" class="text-gray-500 hover:text-[#E4405F] transition-colors" aria-label="Email">
                <svg class="w-5 h-5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
        </div>
        </div>
    </div>

    <!-- Header & Mega Menu -->
    <header class="bg-white shadow-lg sticky top-0 z-50 transition-all duration-300" 
            x-data="{ mobileOpen: false, scrolled: false }"
            @scroll.window="scrolled = (window.pageYOffset > 20)">
        
        <div class="container mx-auto px-4">
            <!-- Top row: Logo + Mobile burger -->
            <div class="flex justify-between items-center transition-all duration-300"
                 :class="scrolled ? 'py-2' : 'py-3'">
                
                <a href="/" class="flex items-center gap-3 group py-1">
                    <img src="/assets/images/logo.png" alt="Логотип Гімназії ПРОСВІТ" class="w-12 h-12 lg:w-14 lg:h-14 object-contain rounded-full group-hover:scale-110 transition-transform duration-300">
                    <div class="flex flex-col justify-center">
                        <span class="block text-lg md:text-xl font-heading font-extrabold text-primary leading-none tracking-tight group-hover:text-blue-700 transition-colors uppercase">
                            ГІМНАЗІЯ "ПРОСВІТ"
                        </span>
                        <span class="text-[0.65rem] md:text-xs text-secondary font-medium leading-tight max-w-[280px] mt-1">
                            Лубенської міської ради Лубенського району Полтавської області
                        </span>
                    </div>
                </a>

                <!-- Mobile Menu Button -->
                <button @click="mobileOpen = !mobileOpen" class="lg:hidden text-gray-700 hover:text-primary focus:outline-none p-2">
                    <svg class="w-6 h-6" x-show="!mobileOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    <svg class="w-6 h-6" x-show="mobileOpen" x-cloak fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Desktop Navigation (separate row, wraps into multiple lines) -->
            <nav class="hidden lg:flex flex-wrap items-center justify-center gap-x-4 gap-y-1 pb-3 border-t border-gray-100 pt-2"
                 :class="scrolled ? 'pb-2 pt-1' : ''">
                {% for item in navigation.root %}
                <div class="relative group" x-data="{ open: false }">
                    {% if item.children.length > 0 %}
                    <button 
                        class="flex items-center py-1.5 text-[0.8rem] xl:text-sm font-bold text-gray-700 hover:text-primary transition-colors uppercase tracking-wide focus:outline-none whitespace-nowrap"
                        @mouseenter="open = true" 
                        @mouseleave="open = false">
                        {{ item.label }}
                        <svg class="w-3.5 h-3.5 ml-0.5 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                        
                        <!-- Underline Effect -->
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
                    </button>

                    <!-- Dropdown Panel -->
                    <div 
                        x-show="open"
                        x-transition:enter="transition ease-out duration-200"
                        x-transition:enter-start="opacity-0 translate-y-2"
                        x-transition:enter-end="opacity-100 translate-y-0"
                        x-transition:leave="transition ease-in duration-150"
                        x-transition:leave-start="opacity-100 translate-y-0"
                        x-transition:leave-end="opacity-0 translate-y-2"
                        @mouseenter="open = true" 
                        @mouseleave="open = false"
                        class="absolute top-full left-0 w-64 bg-white rounded-xl shadow-2xl border border-gray-100 overflow-hidden pt-2 pb-2 mt-2 z-50"
                        style="display: none;">
                        
                        <!-- Little arrow on top -->
                        <div class="absolute -top-2 left-6 w-4 h-4 bg-white transform rotate-45 border-l border-t border-gray-100"></div>

                        {% for child in item.children %}
                        <a href="{{ child.url }}" class="block px-6 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors flex items-center group/item">
                            <span class="w-1.5 h-1.5 rounded-full bg-gray-300 mr-2 group-hover/item:bg-accent transition-colors"></span>
                            {{ child.label }}
                        </a>
                        {% endfor %}
                    </div>
                    {% else %}
                    <a href="{{ item.url }}" class="flex items-center py-1.5 text-[0.8rem] xl:text-sm font-bold text-gray-700 hover:text-primary transition-colors uppercase tracking-wide focus:outline-none relative whitespace-nowrap">
                        {{ item.label }}
                        <!-- Underline Effect -->
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
                    </a>
                    {% endif %}
                </div>
                {% endfor %}

                <!-- CTA Button -->
                <button @click.prevent="contactOpen = true" class="ml-2 px-4 py-2 bg-gradient-to-r from-primary to-teal-500 text-white text-xs xl:text-sm font-bold rounded-full shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 transform whitespace-nowrap">
                    Зв'язатись
                </button>
            </nav>
        </div>

        <!-- Mobile Menu (Overlay) -->
        <div 
            x-show="mobileOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 -translate-y-full"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-full"
            class="lg:hidden absolute top-full left-0 w-full bg-white shadow-2xl border-t border-gray-100 h-[calc(100vh-80px)] overflow-y-auto"
            style="display: none;">
            
            <div class="container mx-auto px-4 py-6 space-y-2">
                {% for item in navigation.root %}
                <div x-data="{ subOpen: false }" class="border-b border-gray-100 last:border-0 pb-2">
                    <div class="flex justify-between items-center">
                        <a href="{{ item.url }}" class="block py-3 text-lg font-bold text-gray-800 hover:text-primary" @click="if({{ item.children.length }} > 0) { $event.preventDefault(); subOpen = !subOpen }">
                            {{ item.label }}
                        </a>
                        {% if item.children.length > 0 %}
                        <button @click="subOpen = !subOpen" class="p-2 text-gray-500">
                            <svg class="w-5 h-5 transition-transform" :class="subOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        {% endif %}
                    </div>
                    
                    {% if item.children.length > 0 %}
                    <div x-show="subOpen" class="pl-4 pb-2 space-y-2 bg-gray-50 rounded-lg mt-1" x-collapse>
                        {% for child in item.children %}
                        <a href="{{ child.url }}" class="block py-2 text-gray-600 hover:text-primary font-medium text-sm">
                            {{ child.label }}
                        </a>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
                
                <div class="pt-6">
                    <button @click="contactOpen = true; mobileOpen = false" class="block w-full text-center px-6 py-3 bg-primary text-white font-bold rounded-lg shadow-md hover:bg-opacity-90">
                        Зв'язатись з нами
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer id="contacts" class="bg-gray-900 text-gray-300 pt-16 pb-8">
        <div class="container mx-auto px-4">
            <div class="grid md:grid-cols-3 gap-8 mb-12">
                <!-- Col 1: Brand -->
                <div>
                     <a href="/" class="flex gap-3 mb-6">
                        <img src="/assets/images/logo.png" alt="Логотип" class="w-16 h-16 rounded-full mt-1 bg-white p-1">
                        <div class="flex flex-col">
                            <span class="text-lg font-heading font-bold text-white tracking-wide uppercase">Гімназія "ПРОСВІТ"</span>
                            <span class="text-xs text-gray-400 mt-1 max-w-[250px] leading-snug">Лубенської міської ради Лубенського району Полтавської області</span>
                        </div>
                    </a>
                    <p class="text-sm text-gray-400 mb-6 leading-relaxed">
                        Сучасний освітній простір, де кожна дитина розкриває свій потенціал.
                    </p>
                    <div class="flex space-x-4">
                        <a href="https://www.facebook.com/gymnasium.prosvit/" target="_blank" class="w-10 h-10 bg-white/10 rounded-full hover:bg-[#1877F2] transition-colors flex items-center justify-center text-white" aria-label="Facebook">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="mailto:school3_lubny@ukr.net" class="w-10 h-10 bg-white/10 rounded-full hover:bg-primary transition-colors flex items-center justify-center text-white" aria-label="Email">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </a>
                    </div>
                </div>

                <!-- Col 3: Contacts -->
                <div>
                    <h3 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Контакти</h3>
                    <ul class="space-y-3 text-sm">
                        <li class="flex items-start">
                            <span class="mr-2">📍</span>
                            <span>Україна, Полтавська область,<br>м. Лубни, вул. Олександрівська, 8/2, 37500</span>
                        </li>
                        <li class="flex items-center">
                            <span class="mr-2">📞</span>
                            <a href="tel:+380536161815" class="hover:text-white transition-colors">+38 (053) 616-18-15</a>
                        </li>
                        <li class="flex items-center">
                            <span class="mr-2">✉️</span>
                            <a href="mailto:school3_lubny@ukr.net" class="hover:text-white transition-colors">school3_lubny@ukr.net</a>
                        </li>
                    </ul>
                </div>

                <!-- Col 4: Map -->
                <div>
                    <h3 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Ми на карті</h3>
                    <div class="h-48 rounded-lg overflow-hidden shadow-lg border border-gray-700">
                        <iframe 
                            src="https://maps.google.com/maps?q=Лубенська+спеціалізована+школа+№3&t=&z=15&ie=UTF8&iwloc=&output=embed"
                            width="100%" 
                            height="100%" 
                            style="border:0;" 
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                    </div>
                </div>
            </div>
            
            <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
                <p>&copy; 2026 Гімназія "ПРОСВІТ" ЛМР. Всі права захищені.</p>
            </div>
        </div>
    </footer>

    <!-- Contact Modal -->
    <div x-show="contactOpen" class="relative z-[100]" aria-labelledby="modal-title" role="dialog" aria-modal="true" style="display: none;" x-cloak>
        <div x-show="contactOpen" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @click="contactOpen = false"></div>

        <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div x-show="contactOpen" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-md">
                    <!-- Gradient Header -->
                    <div class="bg-gradient-to-r from-primary to-teal-400 px-6 py-5 relative">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                  <!-- Form Body -->
                    <div class="px-6 py-5">
                        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/success/">
                            <p class="hidden"><label>Don't fill this out if you're human: <input name="bot-field"/></label></p>
                            <div class="space-y-4">
                                <div>
                                    <label for="contact-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Ваше ім'я <span class="text-rose-500">*</span></label>
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg></span>
                                        <input type="text" name="name" id="contact-name" required placeholder="Іваненко Іван" class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all">
                                    </div>
                                </div>
                                <div>
                                    <label for="contact-email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email <span class="text-rose-500">*</span></label>
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></span>
                                        <input type="email" name="email" id="contact-email" required placeholder="example@gmail.com" class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all">
                                    </div>
                                </div>
                                <div>
                                    <label for="contact-phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Телефон</label>
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></span>
                                        <input type="tel" name="phone" id="contact-phone" placeholder="+38 (0__) ___-__-__" class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all">
                                    </div>
                                </div>
                                <div>
                                    <label for="contact-message" class="block text-sm font-semibold text-gray-700 mb-1.5">Повідомлення <span class="text-rose-500">*</span></label>
                                    <textarea name="message" id="contact-message" rows="3" required placeholder="Ваше запитання або звернення..." class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all resize-none"></textarea>
                                </div>
                            </div>
                            <div class="flex gap-3 mt-5">
                                <button type="button" @click="contactOpen = false" class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition-colors">Скасувати</button>
                                <button type="submit" class="flex-grow px-6 py-2.5 bg-gradient-to-r from-primary to-teal-500 text-white text-sm font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                                    Надіслати
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", user => {
                if (!user) {
                    window.netlifyIdentity.on("login", () => {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
    </script>
</body>
</html>
