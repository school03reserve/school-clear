<div class="my-8 max-w-4xl mx-auto">
    {% if block.title %}
    <h3 class="text-2xl font-heading font-bold text-gray-900 mb-6">{{ block.title }}</h3>
    {% endif %}
    <div class="space-y-4">
        {% for item in block.items %}
        <div class="flex items-start gap-4 bg-white p-5 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-primary to-blue-500 text-white flex items-center justify-center font-bold text-lg shadow-md group-hover:scale-110 transition-transform">
                {{ loop.index }}
            </div>
            <div class="flex-grow pt-1">
                {% if item.title %}
                <h4 class="font-bold text-gray-900 mb-1">{{ item.title }}</h4>
                {% endif %}
                {% if item.description %}
                <div class="text-gray-600 text-sm leading-relaxed prose prose-sm">
                    {{ item.description | markdownify | safe }}
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</div>
