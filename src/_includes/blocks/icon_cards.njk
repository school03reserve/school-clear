{% set colsMap = {
    '2': 'md:grid-cols-2',
    '3': 'md:grid-cols-2 lg:grid-cols-3',
    '4': 'md:grid-cols-2 lg:grid-cols-4'
} %}

{% set cols = colsMap[block.columns] or 'md:grid-cols-2 lg:grid-cols-3' %}

<div class="my-8">
    {% if block.title %}
    <h3 class="text-2xl font-heading font-bold text-gray-900 mb-6 text-center">{{ block.title }}</h3>
    {% endif %}
    <div class="grid {{ cols }} gap-6">
        {% for card in block.cards %}
        <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center group">
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">{{ card.icon }}</div>
            <h4 class="font-bold text-gray-900 text-lg mb-2">{{ card.title }}</h4>
            {% if card.description %}
            <p class="text-gray-600 text-sm leading-relaxed">{{ card.description }}</p>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>
