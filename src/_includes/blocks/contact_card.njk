<div class="my-8 max-w-2xl mx-auto bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow duration-300">
    <div class="flex flex-col sm:flex-row">
        {% if block.photo %}
        <div class="sm:w-40 h-48 sm:h-auto flex-shrink-0">
            <img src="{{ block.photo }}" alt="{{ block.name }}" class="w-full h-full object-cover">
        </div>
        {% endif %}
        <div class="p-6 flex-grow">
            <h3 class="text-xl font-heading font-bold text-gray-900">{{ block.name }}</h3>
            {% if block.position %}
            <p class="text-primary font-semibold text-sm mt-1">{{ block.position }}</p>
            {% endif %}
            {% if block.description %}
            <p class="text-gray-600 text-sm mt-3 leading-relaxed">{{ block.description }}</p>
            {% endif %}
            <div class="flex flex-wrap gap-3 mt-4">
                {% if block.phone %}
                <a href="tel:{{ block.phone }}" class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-primary transition-colors bg-gray-50 px-3 py-1.5 rounded-full">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    {{ block.phone }}
                </a>
                {% endif %}
                {% if block.email %}
                <a href="mailto:{{ block.email }}" class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-primary transition-colors bg-gray-50 px-3 py-1.5 rounded-full">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    {{ block.email }}
                </a>
                {% endif %}
            </div>
            {% if block.schedule %}
            <p class="text-xs text-gray-500 mt-3">🕐 {{ block.schedule }}</p>
            {% endif %}
        </div>
    </div>
</div>
